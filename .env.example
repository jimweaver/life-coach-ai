# Life Coach AI - Environment Configuration Example
# Copy this file to .env and update with your values

# Redis Configuration (Short-term memory)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# PostgreSQL Configuration (Medium-term memory)
DATABASE_URL=postgresql://user@localhost:5432/life_coach
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=life_coach
POSTGRES_USER=user
POSTGRES_PASSWORD=

# Application Configuration
NODE_ENV=development
PORT=8787
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# External APIs (optional - for data collection)
BRAVE_API_KEY=
OPENAI_API_KEY=

# Scheduler Configuration
SCHEDULER_ENABLED=true
SCHEDULER_DELIVERY_MODE=redis

# Alert Routing (optional)
DELIVERY_ALERT_ROUTE_ENABLED=false
DELIVERY_ALERT_ONCALL_SYNC_ENABLED=false

# Deployment Configuration
DEPLOY_WRAPPER_EVENT_SINK=none
DEPLOY_WRAPPER_LOG_FORMAT=text

# Shutdown Configuration
SHUTDOWN_GRACE_MS=30000
