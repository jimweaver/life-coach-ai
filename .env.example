# Life Coach AI - Environment Configuration
# Copy this file to .env and fill in your values

# Node Environment
NODE_ENV=production

# API Configuration
PORT=8787

# Database Configuration (PostgreSQL)
DB_USER=lifecoach
DB_PASSWORD=changeme-strong-password
DB_NAME=life_coach
DB_PORT=5432
DATABASE_URL=postgresql://lifecoach:changeme-strong-password@postgres:5432/life_coach

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# External API Keys (required for full functionality)
OPENAI_API_KEY=sk-your-openai-key-here
BRAVE_API_KEY=your-brave-api-key-here

# Model Configuration
DOMAIN_MODEL_ADAPTER_MODE=auto

# Rate Limiting
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Cron Event Delivery
CRON_EVENT_DELIVERY_MODE=redis
CRON_EVENT_REDIS_LIST_KEY=openclaw:cron-events

# Scheduler Configuration
SCHEDULER_MONITOR_CYCLE_INTERVAL_MS=14400000
SCHEDULER_MORNING_CYCLE_HOUR=9
SCHEDULER_MORNING_CYCLE_MINUTE=0
SCHEDULER_MORNING_CYCLE_TIMEZONE=America/Los_Angeles

# Alert Configuration
DELIVERY_ALERT_ROUTE_STRATEGY=severity
DELIVERY_ALERT_ESCALATION_ENABLED=true
DELIVERY_ALERT_ESCALATION_MIN_LEVEL=critical

# Deploy Wrapper
DEPLOY_WRAPPER_LOG_FORMAT=json
DEPLOY_WRAPPER_EVENT_SINK=postgres

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
