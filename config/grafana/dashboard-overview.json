{
  "dashboard": {
    "title": "Life Coach AI - Overview",
    "tags": ["lifecoach", "overview"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(lifecoach_requests_total[5m])",
            "legendFormat": "{{mode}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "decimals": 2
          }
        },
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "Error Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(lifecoach_errors_total[5m])",
            "legendFormat": "Errors"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "decimals": 3,
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 0.01 },
                { "color": "red", "value": 0.05 }
              ]
            }
          }
        },
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
      },
      {
        "id": 3,
        "title": "Avg Latency",
        "type": "stat",
        "targets": [
          {
            "expr": "lifecoach_request_latency_avg_ms",
            "legendFormat": "Latency"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "decimals": 0,
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 500 },
                { "color": "red", "value": 1000 }
              ]
            }
          }
        },
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
      },
      {
        "id": 4,
        "title": "Uptime",
        "type": "stat",
        "targets": [
          {
            "expr": "lifecoach_uptime_seconds",
            "legendFormat": "Uptime"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "dtdurations"
          }
        },
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
      },
      {
        "id": 5,
        "title": "Requests by Domain",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(lifecoach_requests_total{domain=~\".+\"}[5m])",
            "legendFormat": "{{domain}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "pointSize": 5,
              "showPoints": "auto"
            }
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
      },
      {
        "id": 6,
        "title": "Latency Distribution (p50/p95/p99)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(lifecoach_request_latency_bucket[5m])) by (le))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(lifecoach_request_latency_bucket[5m])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(lifecoach_request_latency_bucket[5m])) by (le))",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms"
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
      },
      {
        "id": 7,
        "title": "Cache Hit Ratio",
        "type": "gauge",
        "targets": [
          {
            "expr": "lifecoach_cache_hit_ratio",
            "legendFormat": "Hit Ratio"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.7 },
                { "color": "green", "value": 0.85 }
              ]
            }
          }
        },
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 12 }
      },
      {
        "id": 8,
        "title": "Cache Operations",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(lifecoach_cache_operations_total[5m])",
            "legendFormat": "{{operation}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "drawStyle": "line",
              "stacking": { "mode": "normal" }
            }
          }
        },
        "gridPos": { "h": 6, "w": 18, "x": 6, "y": 12 }
      },
      {
        "id": 9,
        "title": "Error Types",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum(rate(lifecoach_errors_total[5m])) by (type)",
            "legendFormat": "{{type}}"
          }
        ],
        "options": {
          "legend": { "displayMode": "table", "placement": "right" }
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 }
      },
      {
        "id": 10,
        "title": "Agent Execution by Domain",
        "type": "bargauge",
        "targets": [
          {
            "expr": "lifecoach_agent_executions_total",
            "legendFormat": "{{domain}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "options": {
          "orientation": "horizontal"
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 }
      }
    ]
  }
}
