{
  "dashboard": {
    "title": "Life Coach AI - Model & Integration",
    "tags": ["lifecoach", "model", "delivery", "integration"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Model Call Success Rate",
        "type": "gauge",
        "targets": [
          {
            "expr": "lifecoach_model_call_success_total / lifecoach_model_calls_total",
            "legendFormat": "Success Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.9 },
                { "color": "green", "value": 0.95 }
              ]
            }
          }
        },
        "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "Model Calls by Model",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(lifecoach_model_calls_total[5m])",
            "legendFormat": "{{model}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        },
        "gridPos": { "h": 6, "w": 16, "x": 8, "y": 0 }
      },
      {
        "id": 3,
        "title": "Model Call Duration",
        "type": "timeseries",
        "targets": [
          {
            "expr": "lifecoach_model_call_duration_ms",
            "legendFormat": "{{model}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 1500 },
                { "color": "red", "value": 3000 }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }
      },
      {
        "id": 4,
        "title": "Model Calls by Domain",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum(rate(lifecoach_model_calls_total[5m])) by (domain)",
            "legendFormat": "{{domain}}"
          }
        ],
        "options": {
          "legend": { "displayMode": "table", "placement": "right" }
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }
      },
      {
        "id": 5,
        "title": "Delivery Success Rate",
        "type": "gauge",
        "targets": [
          {
            "expr": "lifecoach_delivery_success_total / lifecoach_deliveries_total",
            "legendFormat": "Success Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.9 },
                { "color": "green", "value": 0.95 }
              ]
            }
          }
        },
        "gridPos": { "h": 6, "w": 8, "x": 0, "y": 14 }
      },
      {
        "id": 6,
        "title": "Deliveries by Mode",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(lifecoach_deliveries_total[5m])",
            "legendFormat": "{{mode}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        },
        "gridPos": { "h": 6, "w": 16, "x": 8, "y": 14 }
      },
      {
        "id": 7,
        "title": "Delivery Response Time",
        "type": "timeseries",
        "targets": [
          {
            "expr": "lifecoach_delivery_response_time_ms",
            "legendFormat": "Response Time"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms"
          }
        },
        "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 }
      },
      {
        "id": 8,
        "title": "Delivery Failures",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(lifecoach_delivery_failure_total[5m])",
            "legendFormat": "Failures"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "red", "value": 0.1 }
              ]
            }
          }
        },
        "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 }
      }
    ]
  }
}
