{
  "dashboard": {
    "title": "Life Coach AI - Performance & Memory",
    "tags": ["lifecoach", "performance", "memory"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Heap Memory Used",
        "type": "timeseries",
        "targets": [
          {
            "expr": "lifecoach_memory_heap_used_bytes",
            "legendFormat": "Heap Used"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20
            }
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "RSS Memory",
        "type": "timeseries",
        "targets": [
          {
            "expr": "lifecoach_memory_rss_bytes",
            "legendFormat": "RSS"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20
            }
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
      },
      {
        "id": 3,
        "title": "Heap Utilization",
        "type": "gauge",
        "targets": [
          {
            "expr": "lifecoach_memory_heap_utilization_ratio",
            "legendFormat": "Utilization"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 0.7 },
                { "color": "red", "value": 0.9 }
              ]
            }
          }
        },
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 }
      },
      {
        "id": 4,
        "title": "Request Latency Heatmap",
        "type": "heatmap",
        "targets": [
          {
            "expr": "sum(rate(lifecoach_request_latency_bucket[5m])) by (le)",
            "legendFormat": "{{le}}"
          }
        ],
        "dataFormat": "tsbuckets",
        "heatmap": {},
        "gridPos": { "h": 6, "w": 18, "x": 6, "y": 8 }
      },
      {
        "id": 5,
        "title": "Agent Execution Time by Domain",
        "type": "timeseries",
        "targets": [
          {
            "expr": "lifecoach_agent_execution_avg_ms",
            "legendFormat": "{{domain}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms"
          }
        },
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 }
      },
      {
        "id": 6,
        "title": "Total Requests",
        "type": "stat",
        "targets": [
          {
            "expr": "lifecoach_requests_total",
            "legendFormat": "Total"
          }
        ],
        "options": {
          "graphMode": "area"
        },
        "gridPos": { "h": 4, "w": 8, "x": 0, "y": 22 }
      },
      {
        "id": 7,
        "title": "Total Errors",
        "type": "stat",
        "targets": [
          {
            "expr": "lifecoach_errors_total",
            "legendFormat": "Errors"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "red", "value": 1 }
              ]
            }
          }
        },
        "gridPos": { "h": 4, "w": 8, "x": 8, "y": 22 }
      },
      {
        "id": 8,
        "title": "Agent Executions",
        "type": "stat",
        "targets": [
          {
            "expr": "lifecoach_agent_executions_total",
            "legendFormat": "Executions"
          }
        ],
        "gridPos": { "h": 4, "w": 8, "x": 16, "y": 22 }
      }
    ]
  }
}
