# === Core runtime ===
NODE_ENV=production
PORT=8787

# === Storage ===
DATABASE_URL=postgresql://tj@localhost:5432/life_coach
REDIS_HOST=localhost
REDIS_PORT=6379

# === Guardrails / Rate limiting ===
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
RATE_LIMIT_MAX_CHAT=60
RATE_LIMIT_MAX_JOBS=20
RATE_LIMIT_MAX_INTERVENTION=80
RATE_LIMIT_MAX_GOALS=40
RATE_LIMIT_KEY_PREFIX=lifecoach:rate-limit

# === Scheduler delivery ===
CRON_DELIVERY_MODE=redis
CRON_EVENT_REDIS_LIST_KEY=lifecoach:cron-events
CRON_EVENT_TIMEOUT_MS=5000
SCHEDULER_DELIVER_MONITOR=true
SCHEDULER_DELIVER_MORNING=true
SCHEDULER_INLINE_RETRY_MAX=1

# === Retry / dead-letter ===
CRON_DELIVERY_RETRY_MAX=5
CRON_DELIVERY_RETRY_BASE_DELAY_MS=1000
CRON_DELIVERY_RETRY_MAX_DELAY_MS=60000

# === Data quality ===
DATA_COLLECTOR_MAX_SOURCE_AGE_DAYS=1200
DATA_COLLECTOR_ENABLE_DEDUPE=true

# === Domain model adapter ===
DOMAIN_MODEL_ADAPTER_MODE=auto
DOMAIN_MODEL_TIMEOUT_MS=12000
DOMAIN_MODEL_RETRY_MAX=2
DOMAIN_MODEL_RETRY_BASE_DELAY_MS=600
